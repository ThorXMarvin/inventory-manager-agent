# ─── LLM Configuration ───────────────────────────────────
# Provider: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# For Ollama (local), set:
# LLM_PROVIDER=ollama
# LLM_API_KEY=not-needed
# LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# ─── WhatsApp (Primary Channel) ──────────────────────────
# Scan QR code on first run to link your WhatsApp number
WHATSAPP_ENABLED=true

# ─── Telegram (Not yet implemented) ─────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ENABLED=false

# ─── Email Notifications (Brevo SMTP) ───────────────────
# For daily reports, low stock alerts, weekly summaries
# Sign up free at https://app.brevo.com — 300 emails/day
# Or configure in business.yaml under channels.email
EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_NAME=Inventory Manager
EMAIL_FROM_EMAIL=
EMAIL_OWNER_EMAIL=

# ─── Web Dashboard ───────────────────────────────────────
WEB_ENABLED=true
WEB_PORT=3000

# ─── Database ────────────────────────────────────────────
DB_PATH=./data/inventory.db

# ─── Google Sheets (optional) ────────────────────────────
# Only needed if storage.mode is "sheets" or "both" in business.yaml
GOOGLE_SHEETS_CREDENTIALS_FILE=./config/google-credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
