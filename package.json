{
  "name": "inventory-manager-agent",
  "version": "1.0.0",
  "description": "WhatsApp/Telegram AI agent for small business inventory management",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/launcher.js",
    "start:direct": "node src/index.js",
    "dev": "node --watch src/index.js",
    "import-csv": "node src/utils/csv-import.js",
    "build": "bash scripts/build-executable.sh",
    "package": "bash scripts/package.sh"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [
      "config/**/*",
      "src/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "dist/executables"
  },
  "keywords": ["inventory", "whatsapp", "telegram", "ai-agent", "stock-management"],
  "author": "AI Studio Uganda",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "openai": "^4.77.0",
    "telegraf": "^4.16.3",
    "winston": "^3.17.0",
    "yaml": "^2.7.0"
  }
}
