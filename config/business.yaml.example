# ─── Business Configuration ──────────────────────────────
# Copy this file to config/business.yaml and customize

business:
  name: "Mukasa Hardware Store"
  type: "retail"           # retail | pharmacy | restaurant | warehouse
  currency: "UGX"          # UGX | KES | TZS | USD
  phone: "+256700000000"
  location: "Kampala, Uganda"

# ─── Storage Configuration ──────────────────────────────
# Supports: sqlite (local), sheets (Google Sheets), or both (hybrid)
storage:
  mode: "sqlite"           # sqlite | sheets | both
  sqlite:
    path: "./data/inventory.db"
  sheets:
    credentials_file: "./config/google-credentials.json"
    spreadsheet_id: ""     # leave empty for auto-create on first run
    spreadsheet_name: "{business_name} - Inventory"

# ─── Product Categories ─────────────────────────────────
categories:
  - name: "Building Materials"
    products:
      - name: "Cement (50kg bag)"
        sku: "CEM-50"
        unit: "bag"
        buy_price: 32000
        sell_price: 38000
        min_stock: 20
        current_stock: 85
      - name: "Iron Sheets (30 gauge)"
        sku: "IRS-30"
        unit: "piece"
        buy_price: 25000
        sell_price: 32000
        min_stock: 50
        current_stock: 120
      - name: "Nails (4 inch)"
        sku: "NAL-4"
        unit: "kg"
        buy_price: 5000
        sell_price: 7000
        min_stock: 15
        current_stock: 40

  - name: "Paint"
    products:
      - name: "Plascon Emulsion (20L)"
        sku: "PNT-E20"
        unit: "tin"
        buy_price: 180000
        sell_price: 220000
        min_stock: 10
        current_stock: 25
      - name: "Sadolin Varnish (5L)"
        sku: "PNT-V5"
        unit: "tin"
        buy_price: 85000
        sell_price: 110000
        min_stock: 5
        current_stock: 12

  - name: "Plumbing"
    products:
      - name: "PVC Pipe (1/2 inch, 6m)"
        sku: "PVC-H6"
        unit: "piece"
        buy_price: 8000
        sell_price: 12000
        min_stock: 20
        current_stock: 45

# ─── Channel Configuration ───────────────────────────────
channels:
  whatsapp:
    respond_to: "all"      # "all" = respond to everyone, "authorized" = only authorized_users
    # Role-based authorization (optional — leave empty to allow everyone)
    authorized_numbers:
      # - name: "Boss"
      #   phone: "+256770000000"
      #   role: "owner"            # owner = full access to all tools
      # - name: "John"
      #   phone: "+256771111111"
      #   role: "staff"            # staff = limited access (no financial reports, no price changes)
    allow_unknown: false            # Allow messages from numbers not in the list above

  email:
    enabled: false         # Set to true to enable email reports/alerts
    smtp_host: "smtp-relay.brevo.com"
    smtp_port: 587
    smtp_user: ""          # Your Brevo SMTP login (email)
    smtp_pass: ""          # Your Brevo SMTP key/password
    from_name: "Inventory Manager"
    from_email: ""         # Verified sender email in Brevo
    owner_email: ""        # Where to send reports and alerts

# ─── Alert Settings ──────────────────────────────────────
alerts:
  low_stock:
    enabled: true
    check_interval: "6h"
    notify_via:
      - "whatsapp"
      - "email"
  daily_summary:
    enabled: true
    time: "20:00"          # 24h format, end of business day

# ─── Report Settings ────────────────────────────────────
reports:
  weekly: true
  monthly: true
  include:
    - "stock_levels"
    - "sales_summary"
    - "profit_margin"
    - "top_sellers"

# ─── Authorized Users (optional) ────────────────────────
# Only these numbers/usernames can interact with the bot
# Leave empty to allow anyone
authorized_users: []
  # - "+256700000001"
  # - "@shop_manager"
